## Copia in `scripts/deploy-aruba.env` (NON committare) e compila.
##
## Aruba SFTP
SFTP_HOST="sftp.tuodominio.it"
SFTP_PORT="22"
SFTP_USER="tuo_user"
SFTP_PASS="tuapassword"

## Percorso remoto dove pubblicare (sottocartella)
## Esempi comuni:
## - "/httpdocs/officinaephone"
## - "/public_html/officinaephone"
REMOTE_DIR="/httpdocs/officinaephone"

## Base URL per Vite (deve matchare la sottocartella pubblica)
## Esempio: se pubblichi su https://tuodominio.it/officinaephone/ allora:
VITE_BASE="/officinaephone/"

## Opzionale: path locale del config DB da caricare come `api/_config.local.php`
## Suggerito tenerlo fuori repo (es. nella home):
# LOCAL_API_CONFIG="/Users/tuo_utente/secrets/officinaephone/_config.local.php"

